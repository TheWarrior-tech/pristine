set -uo pipefail

VERSION="1.0.1"
DRY_RUN=false
DEBUG=false

# ── Guard: macOS only ──────────────────────────────────────────
require_macos() {
  [[ "$(uname)" == "Darwin" ]] || { echo "Pristine requires macOS." >&2; exit 1; }
}

# ── Colors — use printf '\033' to get real ESC char ────────────
setup_colors() {
  if [[ -t 1 ]]; then
    local e
    e=$(printf '\033')
    BOLD="${e}[1m";    DIM="${e}[2m";      RESET="${e}[0m"
    RED="${e}[0;31m";  GREEN="${e}[0;32m"; YELLOW="${e}[0;33m"
    BLUE="${e}[0;34m"; CYAN="${e}[0;36m";  WHITE="${e}[0;37m"
    BRED="${e}[1;31m"; BGREEN="${e}[1;32m";BYELLOW="${e}[1;33m"
    BBLUE="${e}[1;34m";BCYAN="${e}[1;36m"; BWHITE="${e}[1;37m"
    BG_CYAN="${e}[46m";BG_BLUE="${e}[44m"
  else
    BOLD=""; DIM=""; RESET=""; RED=""; GREEN=""; YELLOW=""
    BLUE=""; CYAN=""; WHITE=""; BRED=""; BGREEN=""; BYELLOW=""
    BBLUE=""; BCYAN=""; BWHITE=""; BG_CYAN=""; BG_BLUE=""
  fi
}
setup_colors

# ── Print Helpers ──────────────────────────────────────────────
hr()      { local c="${1:-═}" w="${2:-62}"; printf '%*s\n' "$w" '' | tr ' ' "$c"; }
p_ok()    { printf "  ${GREEN}✓${RESET}  %s\n" "$*"; }
p_info()  { printf "  ${CYAN}→${RESET}  %s\n" "$*"; }
p_warn()  { printf "  ${YELLOW}⚠${RESET}  %s\n" "$*"; }
p_err()   { printf "  ${RED}✗${RESET}  %s\n" "$*" >&2; }

section() {
  printf "\n  ${BWHITE}%s${RESET}\n  ${DIM}%s${RESET}\n" "$1" "$(hr '─' 58)"
}

banner() {
  printf "\n"
  printf "  ${BCYAN}╔═══════════════════════════════════════════════════╗${RESET}\n"
  printf "  ${BCYAN}║${RESET}   ${BWHITE}✦  PRISTINE${RESET}  ${DIM}— Deep clean your Mac${RESET}             ${BCYAN}║${RESET}\n"
  printf "  ${BCYAN}╚═══════════════════════════════════════════════════╝${RESET}\n"
  printf "  ${DIM}v%s · Safe by default · Zero dependencies${RESET}\n\n" "$VERSION"
}

# ── Format KB sizes to human readable ─────────────────────────
fmt_kb() {
  awk -v kb="$1" 'BEGIN{
    if      (kb >= 1048576) printf "%.1fGB", kb/1048576
    else if (kb >= 1024)    printf "%.1fMB", kb/1024
    else if (kb > 0)        printf "%dKB",   kb
    else                    printf "0B"
  }'
}

fmt_bytes() {
  awk -v b="$1" 'BEGIN{
    if      (b >= 1073741824) printf "%.1fGB", b/1073741824
    else if (b >= 1048576)    printf "%.1fMB", b/1048576
    else if (b >= 1024)       printf "%.1fKB", b/1024
    else                      printf "%dB",    b
  }'
}

# ── Visual percentage bar ──────────────────────────────────────
pct_bar() {
  local pct="$1" width="${2:-24}"
  local filled
  filled=$(awk -v p="$pct" -v w="$width" 'BEGIN{x=int(p*w/100); if(x>w)x=w; if(x<0)x=0; print x}')
  local empty=$(( width - filled ))
  [[ $filled -gt 0 ]] && printf "${GREEN}"; printf '%0.s█' $(seq 1 $filled 2>/dev/null) 2>/dev/null; printf "${RESET}"
  [[ $empty  -gt 0 ]] && printf "${DIM}";   printf '%0.s░' $(seq 1 $empty  2>/dev/null) 2>/dev/null; printf "${RESET}"
}

# ── Confirm prompt ─────────────────────────────────────────────
confirm() {
  printf "  ${BYELLOW}?${RESET}  %s ${DIM}[y/N]${RESET} " "$1"
  local ans; read -r ans </dev/tty
  [[ "$ans" =~ ^[Yy]$ ]]
}

# ── Disk size of a path ────────────────────────────────────────
dir_size_kb() { du -sk "$1" 2>/dev/null | awk '{print $1+0}'; }

# ── Check if we can sudo without a password ────────────────────
can_sudo() { sudo -n true 2>/dev/null; }

