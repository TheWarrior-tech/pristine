cmd_clean() {
  banner
  section "Scanning Cache Directories"
  [[ "$DRY_RUN" == true ]] && p_warn "Dry run — no files will be deleted"
  echo ""

  # Define clean targets as parallel arrays (bash 3.2 compat)
  local names=()
  local paths=()

  _add_target() { names+=("$1"); paths+=("$2"); }

  _add_target "User application caches"     "$HOME/Library/Caches"
  _add_target "System log files"            "$HOME/Library/Logs"
  _add_target "Crash reporter logs"         "/Library/Logs/DiagnosticReports"
  _add_target "User crash logs"             "$HOME/Library/Logs/DiagnosticReports"
  _add_target "Temporary files"             "$TMPDIR"
  _add_target "Chrome browser cache"        "$HOME/Library/Application Support/Google/Chrome/Default/Cache"
  _add_target "Chrome GPU cache"            "$HOME/Library/Application Support/Google/Chrome/Default/GPUCache"
  _add_target "Brave browser cache"         "$HOME/Library/Application Support/BraveSoftware/Brave-Browser/Default/Cache"
  _add_target "Firefox cache"              "$HOME/Library/Application Support/Firefox/Profiles"
  _add_target "Safari cache"               "$HOME/Library/Caches/com.apple.Safari"
  _add_target "npm cache"                  "$HOME/.npm/_cacache"
  _add_target "Yarn cache"                 "$HOME/Library/Caches/Yarn"
  _add_target "pnpm cache"                 "$HOME/Library/pnpm/store"
  _add_target "pip cache"                  "$HOME/Library/Caches/pip"
  _add_target "Composer cache"             "$HOME/Library/Caches/composer"
  _add_target "Gradle build cache"         "$HOME/.gradle/caches"
  _add_target "Maven local repository"     "$HOME/.m2/repository"
  _add_target "Go module cache"            "$HOME/go/pkg/mod/cache"
  _add_target "Rust cargo registry"        "$HOME/.cargo/registry/cache"
  _add_target "Xcode DerivedData"          "$HOME/Library/Developer/Xcode/DerivedData"
  _add_target "Xcode device support"       "$HOME/Library/Developer/Xcode/iOS DeviceSupport"
  _add_target "Xcode archives"             "$HOME/Library/Developer/Xcode/Archives"
  _add_target "Simulator caches"           "$HOME/Library/Developer/CoreSimulator/Caches"
  _add_target "Homebrew downloads cache"   "$(brew --cache 2>/dev/null || echo '/tmp/no_brew')"
  _add_target "Docker image cache"         "$HOME/Library/Containers/com.docker.docker/Data"
  _add_target "Slack cache"                "$HOME/Library/Application Support/Slack/Cache"
  _add_target "Spotify cache"              "$HOME/Library/Application Support/Spotify/Data"
  _add_target "VS Code logs"               "$HOME/Library/Application Support/Code/logs"
  _add_target "Adobe media cache"          "$HOME/Library/Application Support/Adobe/Common/Media Cache Files"
  _add_target "Trash"                      "$HOME/.Trash"

  local found_names=()
  local found_paths=()
  local found_sizes=()
  local total_kb=0
  local col_width=44

  for i in "${!names[@]}"; do
    local p="${paths[$i]}"
    if [[ -d "$p" ]] || [[ -f "$p" ]]; then
      local kb
      kb=$(dir_size_kb "$p")
      [[ "$kb" -gt 0 ]] || continue
      found_names+=("${names[$i]}")
      found_paths+=("$p")
      found_sizes+=("$kb")
      total_kb=$(( total_kb + kb ))
      local human; human=$(fmt_kb "$kb")
      printf "  ${GREEN}✓${RESET}  %-${col_width}s  ${BWHITE}%8s${RESET}\n" "${names[$i]}" "$human"
    fi
  done

  echo ""
  local total_human; total_human=$(fmt_kb "$total_kb")
  printf "  ${DIM}%s${RESET}\n" "$(hr '═' 58)"
  printf "  ${BWHITE}Total recoverable: ${BGREEN}%-10s${RESET}  ${DIM}%d locations${RESET}\n" \
    "$total_human" "${#found_names[@]}"
  printf "  ${DIM}%s${RESET}\n\n" "$(hr '═' 58)"

  if [[ ${#found_names[@]} -eq 0 ]]; then
    p_ok "Nothing to clean — your Mac is already spotless!"
    return
  fi

  if [[ "$DRY_RUN" == true ]]; then
    p_info "Dry run complete. Remove --dry-run to actually clean."
    return
  fi

  confirm "Clean all ${#found_names[@]} cache locations (${total_human})?" || { p_info "Aborted."; return; }

  section "Cleaning"
  echo ""

  local freed_kb=0
  for i in "${!found_paths[@]}"; do
    local p="${found_paths[$i]}"
    local kb="${found_sizes[$i]}"
    local name="${found_names[$i]}"
    local human; human=$(fmt_kb "$kb")

    printf "  ${CYAN}→${RESET}  %-${col_width}s" "$name..."
    if rm -rf "${p:?}"/* 2>/dev/null; then
      printf "  ${GREEN}freed %-8s${RESET}\n" "$human"
      freed_kb=$(( freed_kb + kb ))
    else
      printf "  ${YELLOW}skipped${RESET}\n"
    fi
  done

  local freed_human; freed_human=$(fmt_kb "$freed_kb")
  local now_free; now_free=$(df -k / 2>/dev/null | awk 'NR==2{print $4+0}')
  local now_human; now_human=$(fmt_kb "$now_free")

  echo ""
  printf "  ${DIM}%s${RESET}\n" "$(hr '═' 58)"
  printf "  ${BGREEN}✓ Space freed: %-10s${RESET}  ${DIM}Free now: %s${RESET}\n" "$freed_human" "$now_human"
  printf "  ${DIM}%s${RESET}\n\n" "$(hr '═' 58)"
}

