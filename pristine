# ╚══════════════════════════════════════════════════════════════╝

cmd_clean() {
  require_macos
  banner
  section "Scanning Cache Directories"
  [[ "$DRY_RUN" == true ]] && p_warn "Dry run — no files will be deleted"
  echo ""

  local names=() paths=()

  _add() { names+=("$1"); paths+=("$2"); }

  _add "User application caches"       "$HOME/Library/Caches"
  _add "System log files"              "$HOME/Library/Logs"
  _add "Crash reporter logs"           "$HOME/Library/Logs/DiagnosticReports"
  _add "Temporary files"              "${TMPDIR:-/tmp}"
  _add "Chrome browser cache"          "$HOME/Library/Application Support/Google/Chrome/Default/Cache"
  _add "Chrome GPU cache"              "$HOME/Library/Application Support/Google/Chrome/Default/GPUCache"
  _add "Brave browser cache"           "$HOME/Library/Application Support/BraveSoftware/Brave-Browser/Default/Cache"
  _add "Firefox profiles cache"        "$HOME/Library/Application Support/Firefox/Profiles"
  _add "Safari cache"                  "$HOME/Library/Caches/com.apple.Safari"
  _add "npm cache"                     "$HOME/.npm/_cacache"
  _add "Yarn cache"                    "$HOME/Library/Caches/Yarn"
  _add "pnpm store"                    "$HOME/Library/pnpm/store"
  _add "pip cache"                     "$HOME/Library/Caches/pip"
  _add "Composer cache"                "$HOME/Library/Caches/composer"
  _add "Gradle build cache"            "$HOME/.gradle/caches"
  _add "Maven repository cache"        "$HOME/.m2/repository"
  _add "Go module cache"               "$HOME/go/pkg/mod/cache"
  _add "Rust cargo registry"           "$HOME/.cargo/registry/cache"
  _add "Xcode DerivedData"             "$HOME/Library/Developer/Xcode/DerivedData"
  _add "Xcode iOS DeviceSupport"       "$HOME/Library/Developer/Xcode/iOS DeviceSupport"
  _add "Xcode Archives"                "$HOME/Library/Developer/Xcode/Archives"
  _add "CoreSimulator caches"          "$HOME/Library/Developer/CoreSimulator/Caches"
  _add "Homebrew downloads cache"      "$(brew --cache 2>/dev/null || echo '/dev/null/no_brew')"
  _add "Docker container data"         "$HOME/Library/Containers/com.docker.docker/Data/vms"
  _add "Slack cache"                   "$HOME/Library/Application Support/Slack/Cache"
  _add "Spotify cache"                 "$HOME/Library/Application Support/Spotify/Data"
  _add "VS Code logs"                  "$HOME/Library/Application Support/Code/logs"
  _add "Adobe media cache"             "$HOME/Library/Application Support/Adobe/Common/Media Cache Files"
  _add "Trash"                         "$HOME/.Trash"

  local found_names=() found_paths=() found_sizes=()
  local total_kb=0

  for i in "${!names[@]}"; do
    local p="${paths[$i]}"
    [[ -d "$p" || -f "$p" ]] || continue
    local kb; kb=$(dir_size_kb "$p")
    [[ "$kb" -gt 0 ]] || continue
    found_names+=("${names[$i]}")
    found_paths+=("$p")
    found_sizes+=("$kb")
    total_kb=$(( total_kb + kb ))
    printf "  ${GREEN}✓${RESET}  %-44s  ${BWHITE}%8s${RESET}\n" "${names[$i]}" "$(fmt_kb "$kb")"
  done

  if [[ ${#found_names[@]} -eq 0 ]]; then
    echo ""
    p_ok "Nothing to clean — your Mac is already spotless!"
    return
  fi

  echo ""
  printf "  ${DIM}%s${RESET}\n" "$(hr '═' 58)"
  printf "  ${BWHITE}Total recoverable: ${BGREEN}%-10s${RESET}  ${DIM}%d locations${RESET}\n" \
    "$(fmt_kb "$total_kb")" "${#found_names[@]}"
  printf "  ${DIM}%s${RESET}\n\n" "$(hr '═' 58)"

  if [[ "$DRY_RUN" == true ]]; then
    p_info "Dry run complete. Run without --dry-run to actually clean."
    return
  fi

  confirm "Clean all ${#found_names[@]} cache locations ($(fmt_kb "$total_kb"))?" || {
    p_info "Aborted."
    return
  }

  section "Cleaning"
  echo ""

  local freed_kb=0
  for i in "${!found_paths[@]}"; do
    local p="${found_paths[$i]}"
    local kb="${found_sizes[$i]}"
    printf "  ${CYAN}→${RESET}  %-46s" "${found_names[$i]}..."
    if rm -rf "${p:?}"/* 2>/dev/null; then
      printf "  ${GREEN}freed %-8s${RESET}\n" "$(fmt_kb "$kb")"
      freed_kb=$(( freed_kb + kb ))
    else
      printf "  ${YELLOW}skipped${RESET}\n"
    fi
  done

  local now_free; now_free=$(df -k / 2>/dev/null | awk 'NR==2{print $4+0}')
  echo ""
  printf "  ${DIM}%s${RESET}\n" "$(hr '═' 58)"
  printf "  ${BGREEN}✓ Space freed: %-10s${RESET}  ${DIM}Free now: %s${RESET}\n" \
    "$(fmt_kb "$freed_kb")" "$(fmt_kb "$now_free")"
  printf "  ${DIM}%s${RESET}\n\n" "$(hr '═' 58)"
}

