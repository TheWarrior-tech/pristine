# ║  STATUS DASHBOARD                                            ║
# ╚══════════════════════════════════════════════════════════════╝

_cpu_pct() {
  # Sample CPU twice for an accurate reading
  top -l 2 -n 0 -s 1 2>/dev/null | awk '/CPU usage/{
    gsub(/%/,""); n++
    if(n==2){ match($0, /([0-9.]+)% user/, u); match($0, /([0-9.]+)% sys/, s); printf "%.0f", u[1]+s[1] }
  }' 2>/dev/null || echo "0"
}

_mem_info() {
  local page_size total active wired compr used pct
  page_size=$(sysctl -n hw.pagesize 2>/dev/null || echo 4096)
  total=$(sysctl -n hw.memsize 2>/dev/null || echo 0)
  active=$(vm_stat 2>/dev/null | awk '/Pages active/{gsub(/\./,""); print $3+0}')
  wired=$(vm_stat 2>/dev/null  | awk '/Pages wired/{gsub(/\./,""); print $4+0}')
  compr=$(vm_stat 2>/dev/null  | awk '/compressor/{gsub(/\./,""); print $5+0}')
  used=$(( (active + wired + compr) * page_size ))
  pct=$(awk -v u="$used" -v t="$total" 'BEGIN{if(t>0) printf "%.0f", u*100/t; else print 0}')
  printf "%s|%s|%s" "$(fmt_bytes "$used")" "$(fmt_bytes "$total")" "$pct"
}

_disk_info() {
  df -k / 2>/dev/null | awk 'NR==2{
    u=$3; t=$2; f=$4
    pct=(t>0)? int(u*100/t) : 0
    printf "%d|%d|%d\n", f, t, pct
  }'
}

_batt_info() {
  local raw pct status
  raw=$(pmset -g batt 2>/dev/null)
  pct=$(echo "$raw" | grep -o '[0-9]*%' | head -1 | tr -d '%')
  status=$(echo "$raw" | grep -oE '(Charging|AC attached|discharging|charged|finishing charge)' | head -1)
  printf "%s|%s" "${pct:-AC}" "${status:-Unknown}"
}

_top_procs() {
  ps -axro 'comm,pcpu' 2>/dev/null | awk 'NR>1 && NR<=6{
    gsub(/.*\//,"",$1)
    printf "  %-22s %5.1f%%\n", $1, $2
  }'
}

_health() {
  awk -v c="$1" -v m="$2" -v d="$3" 'BEGIN{
    s=100
    if(c>80)s-=25; else if(c>60)s-=15; else if(c>40)s-=5
    if(m>90)s-=20; else if(m>75)s-=10; else if(m>60)s-=3
    if(d>90)s-=20; else if(d>80)s-=10; else if(d>70)s-=3
    print int(s)
  }'
}

cmd_status() {
  require_macos

  local model host os_ver mem_gb
  model=$(sysctl -n machdep.cpu.brand_string 2>/dev/null | cut -c1-30 || echo "Mac")
  host=$(hostname -s 2>/dev/null || echo "Mac")
  os_ver=$(sw_vers -productVersion 2>/dev/null || echo "macOS")
  mem_gb=$(sysctl -n hw.memsize 2>/dev/null | awk '{printf "%.0fGB",$1/1073741824}')

  tput civis 2>/dev/null
  trap 'tput cnorm 2>/dev/null; tput rmcup 2>/dev/null; printf "\n"; exit 0' INT TERM EXIT
  tput smcup 2>/dev/null
  clear

  while true; do
    tput cup 0 0 2>/dev/null

    local cpu mem_info mem_used mem_tot mem_pct
    local disk_info disk_free disk_tot disk_pct
    local batt_pct batt_status health hc
    local load_str uptime_str

    cpu=$(_cpu_pct)
    mem_info=$(_mem_info)
    mem_used="${mem_info%%|*}"; mem_info="${mem_info#*|}"
    mem_tot="${mem_info%%|*}";  mem_pct="${mem_info##*|}"

    disk_info=$(_disk_info)
    disk_free="${disk_info%%|*}"; disk_info="${disk_info#*|}"
    disk_tot="${disk_info%%|*}";  disk_pct="${disk_info##*|}"

    batt_pct=$(_batt_info | cut -d'|' -f1)
    batt_status=$(_batt_info | cut -d'|' -f2)

    health=$(_health "$cpu" "${mem_pct:-0}" "${disk_pct:-0}")
    hc="$BGREEN"; [[ "$health" -lt 80 ]] && hc="$BYELLOW"; [[ "$health" -lt 60 ]] && hc="$BRED"

    load_str=$(uptime 2>/dev/null | awk -F'load averages:' '{print $2}' | xargs)
    uptime_str=$(uptime 2>/dev/null | awk -F'up ' '{print $2}' | awk -F', [0-9]+ user' '{print $1}' | xargs)

    printf "\n"
    printf "  ${BCYAN}${BOLD}PRISTINE STATUS${RESET}  ${DIM}Health ${hc}●${RESET}${hc}%d${RESET}  ${DIM}%s · %s · %s · macOS %s${RESET}\n" \
      "$health" "$host" "$model" "$mem_gb" "$os_ver"
    printf "\n"

    printf "  ${BWHITE}⚙  CPU${RESET}\n"
    printf "  Total   $(pct_bar "${cpu:-0}" 28)  ${BWHITE}%3s%%${RESET}\n" "${cpu:-0}"
    printf "  Load    ${DIM}%s${RESET}\n\n" "$load_str"

    printf "  ${BWHITE}▦  Memory${RESET}\n"
    printf "  Used    $(pct_bar "${mem_pct:-0}" 28)  ${BWHITE}%3s%%${RESET}\n" "${mem_pct:-0}"
    printf "  Usage   ${DIM}%s / %s${RESET}\n\n" "$mem_used" "$mem_tot"

    printf "  ${BWHITE}▤  Disk  ${DIM}(/)${RESET}\n"
    printf "  Used    $(pct_bar "${disk_pct:-0}" 28)  ${BWHITE}%3s%%${RESET}\n" "${disk_pct:-0}"
    printf "  Free    ${DIM}%s free of %s total${RESET}\n\n" "$(fmt_kb "$disk_free")" "$(fmt_kb "$disk_tot")"

    printf "  ${BWHITE}⚡ Battery${RESET}\n"
    if [[ "$batt_pct" == "AC" ]]; then
      printf "  Power   ${DIM}AC Power (desktop/no battery)${RESET}\n\n"
    else
      printf "  Level   $(pct_bar "${batt_pct:-0}" 28)  ${BWHITE}%3s%%${RESET}\n" "${batt_pct:-0}"
      printf "  Status  ${DIM}%s${RESET}\n\n" "$batt_status"
    fi

    printf "  ${BWHITE}▶  Top Processes${RESET}\n"
    _top_procs

    printf "\n  ${DIM}%s${RESET}\n" "$(hr '─' 58)"
    printf "  ${DIM}Auto-refreshes every 2s · Press ${RESET}${BWHITE}q${RESET}${DIM} to quit${RESET}\n"

    if read -r -s -n1 -t 2 k </dev/tty 2>/dev/null; then
      [[ "$k" == "q" || "$k" == "Q" ]] && break
    fi
    clear
  done

  tput cnorm 2>/dev/null
  tput rmcup 2>/dev/null
}

