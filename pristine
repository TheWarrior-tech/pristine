# ╔══════════════════════════════════════════════════════════════╗
# ║  ENTRY POINT                                                 ║
# ╚══════════════════════════════════════════════════════════════╝

main() {
  require_macos

  local command="${1:-menu}"
  shift 2>/dev/null || true

  # Parse flags
  local extra_args=()
  for arg in "$@"; do
    case "$arg" in
      --dry-run)       DRY_RUN=true ;;
      --debug)         DEBUG=true ;;
      --version|-v)    echo "Pristine v${VERSION}"; exit 0 ;;
      --help|-h)       cmd_help; exit 0 ;;
      *)               extra_args+=("$arg") ;;
    esac
  done

  case "$command" in
    menu|"")       cmd_menu ;;
    clean)         cmd_clean ;;
    optimize)      cmd_optimize ;;
    analyze)       cmd_analyze "${extra_args[0]:-}" ;;
    uninstall)     cmd_uninstall ;;
    purge)         cmd_purge ;;
    status)        cmd_status ;;
    doctor)        cmd_doctor ;;
    --help|-h)     cmd_help ;;
    --version|-v)  echo "Pristine v${VERSION}"; exit 0 ;;
    *)
      p_err "Unknown command: $command"
      echo ""
      cmd_help
      exit 1
      ;;
  esac
}

main "$@"
