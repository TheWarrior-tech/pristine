cmd_help() {
  banner
  printf "  ${BWHITE}USAGE${RESET}\n"
  printf "    pristine [command] [options]\n\n"

  printf "  ${BWHITE}COMMANDS${RESET}\n"
  printf "    ${CYAN}pristine${RESET}                  Interactive menu (default)\n"
  printf "    ${CYAN}pristine clean${RESET}            Deep clean caches, logs & browser data\n"
  printf "    ${CYAN}pristine optimize${RESET}         Flush DNS, run maintenance, rebuild services\n"
  printf "    ${CYAN}pristine analyze${RESET} [path]   Visual disk space breakdown (default: ~)\n"
  printf "    ${CYAN}pristine uninstall${RESET}        Remove apps and all their hidden files\n"
  printf "    ${CYAN}pristine purge${RESET}            Delete build artifacts (node_modules etc.)\n"
  printf "    ${CYAN}pristine status${RESET}           Live system health dashboard\n"
  printf "    ${CYAN}pristine doctor${RESET}           Full health check (read-only, always safe)\n\n"

  printf "  ${BWHITE}OPTIONS${RESET}\n"
  printf "    ${CYAN}--dry-run${RESET}                 Preview changes without deleting anything\n"
  printf "    ${CYAN}--version, -v${RESET}             Show version number\n"
  printf "    ${CYAN}--help, -h${RESET}                Show this help\n\n"

  printf "  ${BWHITE}EXAMPLES${RESET}\n"
  printf "    pristine                      Launch interactive menu\n"
  printf "    pristine clean --dry-run      Preview what would be cleaned (safe)\n"
