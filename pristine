cmd_optimize() {
  banner
  section "System Optimization"
  [[ "$DRY_RUN" == true ]] && p_warn "Dry run — no changes will be made"

  # Show system summary
  local disk_used disk_total mem_gb uptime_str os_ver
  disk_used=$(df -k / 2>/dev/null | awk 'NR==2{print $3+0}')
  disk_total=$(df -k / 2>/dev/null | awk 'NR==2{print $2+0}')
  mem_gb=$(sysctl -n hw.memsize 2>/dev/null | awk '{printf "%dGB", $1/1073741824}')
  uptime_str=$(uptime 2>/dev/null | awk -F'up ' '{print $2}' | awk -F',' '{print $1}' | xargs)
  os_ver=$(sw_vers -productVersion 2>/dev/null)

  printf "\n  ${DIM}macOS %s · %s RAM · %s / %s disk · Uptime: %s${RESET}\n\n" \
    "$os_ver" "$mem_gb" "$(fmt_kb "$disk_used")" "$(fmt_kb "$disk_total")" "$uptime_str"

  _run_step() {
    local name="$1" cmd="$2"
    printf "  ${CYAN}→${RESET}  %-48s" "$name..."
    if [[ "$DRY_RUN" == true ]]; then
      printf "  ${DIM}dry-run${RESET}\n"; return
    fi
    if eval "$cmd" 2>/dev/null; then
      printf "  ${GREEN}✓${RESET}\n"
    else
      printf "  ${YELLOW}skipped${RESET}\n"
    fi
  }

  _run_step "Flush DNS cache"                  "sudo dscacheutil -flushcache; sudo killall -HUP mDNSResponder"
  _run_step "Rebuild Dock"                     "killall Dock"
  _run_step "Restart Finder"                   "killall Finder"
  _run_step "Flush system font cache"          "sudo atsutil databases -removeUser"
  _run_step "Run daily maintenance scripts"    "sudo periodic daily"
  _run_step "Run weekly maintenance scripts"   "sudo periodic weekly"
  _run_step "Remove quarantine attributes"     "xattr -d -r com.apple.quarantine ~/Downloads 2>/dev/null || true"
  _run_step "Clear old .DS_Store files"        "find ~ -name '.DS_Store' -type f -delete 2>/dev/null || true"
  _run_step "Rebuild Launch Services database" "/System/Library/Frameworks/CoreServices.framework/Frameworks/LaunchServices.framework/Support/lsregister -kill -r -domain local -domain system -domain user"
  _run_step "Purge inactive memory"            "sudo purge"
  _run_step "Flush bash history duplicates"    "sort -u ~/.bash_history > /tmp/.bh_clean && mv /tmp/.bh_clean ~/.bash_history 2>/dev/null || true"
  _run_step "Update locate database (async)"   "sudo /usr/libexec/locate.updatedb &"

  echo ""
  printf "  ${DIM}%s${RESET}\n" "$(hr '═' 58)"
  printf "  ${BGREEN}✓ System optimization complete${RESET}\n"
  printf "  ${DIM}%s${RESET}\n\n" "$(hr '═' 58)"
}

