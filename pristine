# ║  UNINSTALL                                                   ║
# ╚══════════════════════════════════════════════════════════════╝

_find_app_artifacts() {
  local name="$1"
  local -a search_locs=(
    "$HOME/Library/Application Support"
    "$HOME/Library/Caches"
    "$HOME/Library/Preferences"
    "$HOME/Library/Logs"
    "$HOME/Library/Saved Application State"
    "$HOME/Library/Containers"
    "$HOME/Library/Group Containers"
    "$HOME/Library/WebKit"
    "$HOME/Library/LaunchAgents"
    "/Library/Application Support"
    "/Library/Preferences"
    "/Library/LaunchAgents"
    "/Library/LaunchDaemons"
    "/Library/PrivilegedHelperTools"
  )

  for loc in "${search_locs[@]}"; do
    [[ -d "$loc" ]] || continue
    find "$loc" -maxdepth 2 \( -name "*${name}*" -o -name "*${name,,}*" \) 2>/dev/null
  done
}

cmd_uninstall() {
  require_macos
  banner
  section "Smart App Uninstaller"
  p_info "Scanning installed applications..."
  echo ""

  local -a app_paths=()
  local -a app_names=()
  local -a app_sizes=()

  while IFS= read -r app; do
    [[ -z "$app" ]] && continue
    local kb; kb=$(dir_size_kb "$app")
    app_paths+=("$app")
    app_names+=("$(basename "$app" .app)")
    app_sizes+=("$kb")
  done < <(find /Applications "$HOME/Applications" -maxdepth 1 -name "*.app" 2>/dev/null | sort)

  if [[ ${#app_paths[@]} -eq 0 ]]; then
    p_warn "No applications found."
    return
  fi

  printf "  ${DIM}%-3s  %-36s  %9s${RESET}\n" "#" "Application" "Size"
  printf "  ${DIM}%s${RESET}\n" "$(hr '─' 52)"

  for i in "${!app_paths[@]}"; do
    local human; human=$(fmt_kb "${app_sizes[$i]}")
    printf "  ${DIM}%2d.${RESET}  ${CYAN}%-36s${RESET}  ${BWHITE}%9s${RESET}\n" \
      "$((i+1))" "${app_names[$i]:0:36}" "$human"
  done

  echo ""
  printf "  ${BYELLOW}→${RESET}  Enter number(s) to uninstall ${DIM}(e.g. 1 3 5, or q to quit)${RESET}: "
  local selection; read -r selection
  [[ "$selection" == "q" || "$selection" == "Q" ]] && { p_info "Aborted."; return; }

  for num in $selection; do
    [[ "$num" =~ ^[0-9]+$ ]] || continue
    local idx=$(( num - 1 ))
    [[ $idx -lt 0 || $idx -ge ${#app_paths[@]} ]] && { p_warn "Invalid number: $num"; continue; }

    local app="${app_paths[$idx]}"
    local name="${app_names[$idx]}"
    local app_kb="${app_sizes[$idx]}"

    echo ""
    printf "  ${BWHITE}Uninstalling: ${BCYAN}%s${RESET}\n" "$name"
    printf "  ${DIM}%s${RESET}\n" "$(hr '─' 52)"

    local -a artifacts=()
    while IFS= read -r item; do
      [[ -n "$item" ]] && artifacts+=("$item")
    done < <(_find_app_artifacts "$name")

    printf "  Found ${BWHITE}%d${RESET} associated files/folders\n" "${#artifacts[@]}"
    for a in "${artifacts[@]}"; do
      printf "    ${DIM}• %s${RESET}\n" "${a/$HOME/~}"
    done
    echo ""

    [[ "$DRY_RUN" == true ]] && p_warn "Dry run — nothing will be deleted"
    confirm "Permanently remove $name and all associated files?" || { p_info "Skipping $name."; continue; }

    local freed_kb=0
    printf "  ${CYAN}→${RESET}  Removing application bundle..."
    if [[ "$DRY_RUN" == true ]]; then
      printf " ${DIM}dry-run${RESET}\n"
    elif rm -rf "$app" 2>/dev/null; then
      printf " ${GREEN}✓${RESET}\n"
      freed_kb=$(( freed_kb + app_kb ))
    else
      printf " ${YELLOW}failed${RESET}\n"
    fi

    for artifact in "${artifacts[@]}"; do
      local akb; akb=$(dir_size_kb "$artifact")
      printf "  ${CYAN}→${RESET}  Removing %s..." "${artifact/$HOME/~}"
      if [[ "$DRY_RUN" == true ]]; then
        printf " ${DIM}dry-run${RESET}\n"
      elif rm -rf "$artifact" 2>/dev/null; then
        printf " ${GREEN}✓${RESET}\n"
        freed_kb=$(( freed_kb + akb ))
      else
        printf " ${YELLOW}failed${RESET}\n"
      fi
    done

    local freed_human; freed_human=$(fmt_kb "$freed_kb")
    printf "\n  ${DIM}%s${RESET}\n" "$(hr '─' 52)"
    printf "  ${BGREEN}✓ Freed %s from %s${RESET}\n\n" "$freed_human" "$name"
  done
}

# ╔══════════════════════════════════════════════════════════════╗
# ║  PURGE (Build Artifacts)                                     ║
# ╚══════════════════════════════════════════════════════════════╝

cmd_purge() {
  require_macos
  banner
  section "Project Artifact Purge"
  [[ "$DRY_RUN" == true ]] && p_warn "Dry run — no files will be deleted"
  p_info "Scanning for build artifacts..."
  echo ""

  local -a scan_dirs=(
    "$HOME/Desktop"
    "$HOME/Documents"
    "$HOME/Projects"
    "$HOME/dev"
    "$HOME/Developer"
    "$HOME/Code"
    "$HOME/Work"
    "$HOME/Sites"
    "$HOME/github"
    "$HOME/repos"
  )

  # Custom paths from config
  local cfg="$HOME/.config/pristine/purge_paths"
  if [[ -f "$cfg" ]]; then
    while IFS= read -r line; do
      [[ -n "$line" && ! "$line" =~ ^# ]] && scan_dirs+=("$line")
    done < "$cfg"
  fi

  local -a patterns=(
    "node_modules" "target" ".build" "build" "dist"
    "__pycache__" ".pytest_cache" "venv" ".venv"
    ".gradle" ".dart_tool" "Pods" ".next"
    ".nuxt" ".output" ".svelte-kit" "out"
  )

  local tmpfile; tmpfile=$(mktemp /tmp/pristine_purge.XXXXXX)

  for dir in "${scan_dirs[@]}"; do
    [[ -d "$dir" ]] || continue
    for pattern in "${patterns[@]}"; do
      find "$dir" -maxdepth 7 -type d -name "$pattern" -prune 2>/dev/null | while read -r found; do
        local kb; kb=$(dir_size_kb "$found")
        [[ "$kb" -gt 0 ]] && echo "${kb}	${found}"
      done
    done
  done | sort -rn > "$tmpfile"

  local -a found_paths=()
  local -a found_sizes=()
  local total_kb=0

  while IFS=$'\t' read -r kb path; do
    [[ -z "$kb" || -z "$path" ]] && continue
    found_paths+=("$path")
    found_sizes+=("$kb")
    total_kb=$(( total_kb + kb ))
  done < "$tmpfile"
  rm -f "$tmpfile"

  if [[ ${#found_paths[@]} -eq 0 ]]; then
    p_ok "No build artifacts found — projects are already clean!"
    return
  fi

  local total_human; total_human=$(fmt_kb "$total_kb")
  printf "  ${DIM}Found %d artifact directories · %s total${RESET}\n\n" \
    "${#found_paths[@]}" "$total_human"

  printf "  ${DIM}%-3s  %-50s  %9s${RESET}\n" "#" "Path" "Size"
  printf "  ${DIM}%s${RESET}\n" "$(hr '─' 66)"

  for i in "${!found_paths[@]}"; do
    local path="${found_paths[$i]}"
    local kb="${found_sizes[$i]}"
    local short="${path/$HOME/~}"
    local human; human=$(fmt_kb "$kb")
    printf "  ${DIM}%2d.${RESET}  ${CYAN}%-50s${RESET}  ${BWHITE}%9s${RESET}\n" \
      "$((i+1))" "${short:0:50}" "$human"
  done

  echo ""
  printf "  ${BYELLOW}→${RESET}  Enter numbers to purge ${DIM}(e.g. 1-5, 'all', or q to quit)${RESET}: "
  local selection; read -r selection
  [[ "$selection" == "q" || "$selection" == "Q" ]] && { p_info "Aborted."; return; }

  local -a indices=()
  if [[ "$selection" == "all" ]]; then
    for i in "${!found_paths[@]}"; do indices+=("$i"); done
  else
    # Support ranges like 1-5
    for token in $selection; do
      if [[ "$token" =~ ^([0-9]+)-([0-9]+)$ ]]; then
        local s="${BASH_REMATCH[1]}" e="${BASH_REMATCH[2]}"
        for (( n=s; n<=e; n++ )); do indices+=$(( n - 1 )); done
      elif [[ "$token" =~ ^[0-9]+$ ]]; then
        indices+=("$(( token - 1 ))")
      fi
    done
  fi

  [[ ${#indices[@]} -eq 0 ]] && { p_warn "No valid selection."; return; }

  local sel_kb=0
  for idx in "${indices[@]}"; do
    [[ $idx -ge 0 && $idx -lt ${#found_paths[@]} ]] && sel_kb=$(( sel_kb + found_sizes[$idx] ))
  done

  local sel_human; sel_human=$(fmt_kb "$sel_kb")
  echo ""
  confirm "Permanently delete ${#indices[@]} artifact directories (${sel_human})?" || { p_info "Aborted."; return; }

  section "Purging"
  echo ""

  local freed_kb=0
  for idx in "${indices[@]}"; do
    [[ $idx -lt 0 || $idx -ge ${#found_paths[@]} ]] && continue
    local path="${found_paths[$idx]}"
    local kb="${found_sizes[$idx]}"
    local short="${path/$HOME/~}"

    printf "  ${CYAN}→${RESET}  %-55s" "${short:0:55}..."
    if [[ "$DRY_RUN" == true ]]; then
      printf "  ${DIM}dry-run${RESET}\n"
    elif rm -rf "${path:?}" 2>/dev/null; then
      local human; human=$(fmt_kb "$kb")
      printf "  ${GREEN}✓ %s${RESET}\n" "$human"
      freed_kb=$(( freed_kb + kb ))
    else
      printf "  ${YELLOW}failed${RESET}\n"
    fi
  done

  local freed_human; freed_human=$(fmt_kb "$freed_kb")
  echo ""
  printf "  ${DIM}%s${RESET}\n" "$(hr '═' 58)"
  printf "  ${BGREEN}✓ Space freed: %s${RESET}\n" "$freed_human"
  printf "  ${DIM}%s${RESET}\n\n" "$(hr '═' 58)"
}

