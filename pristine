# ║  ANALYZE                                                     ║
# ╚══════════════════════════════════════════════════════════════╝

cmd_analyze() {
  require_macos
  local target="${1:-$HOME}"
  [[ -d "$target" ]] || { p_err "Path not found: $target"; exit 1; }

  banner
  section "Disk Analyzer  ${DIM}$(echo "$target" | sed "s|$HOME|~|")"
  p_info "Scanning... (this may take a moment)"
  echo ""

  local tmpfile; tmpfile=$(mktemp /tmp/pristine_analyze.XXXXXX)
  du -sk "${target}/"* 2>/dev/null | sort -rn | head -25 > "$tmpfile"

  local -a esizes=() epaths=()
  local total_kb=0

  while IFS=$'\t' read -r kb path; do
    [[ -z "$kb" || -z "$path" ]] && continue
    esizes+=("$kb"); epaths+=("$path")
    total_kb=$(( total_kb + kb ))
  done < "$tmpfile"
  rm -f "$tmpfile"

  if [[ ${#esizes[@]} -eq 0 ]]; then
    p_warn "Nothing found in $target"; return
  fi

  local max_kb="${esizes[0]}"
  [[ "$max_kb" -lt 1 ]] && max_kb=1

  printf "  ${DIM}%-3s  %-36s  %9s  %-20s  %s${RESET}\n" "#" "Name" "Size" "Usage" "%"
  printf "  ${DIM}%s${RESET}\n" "$(hr '─' 72)"

  for i in "${!epaths[@]}"; do
    local path="${epaths[$i]}" kb="${esizes[$i]}"
    local name; name=$(basename "$path")
    local pct;  pct=$(awk -v k="$kb" -v t="$total_kb" 'BEGIN{if(t>0)printf "%.0f",k*100/t; else print 0}')
    local blen; blen=$(awk -v k="$kb" -v m="$max_kb" 'BEGIN{x=int(k*18/m); if(x<1)x=1; print x}')
    local bar=""; for (( b=0; b<blen; b++ )); do bar+="█"; done
    local icon="📄"; [[ -d "$path" ]] && icon="📁"

    printf "  ${DIM}%2d.${RESET}  ${CYAN}%-35s${RESET}  ${BWHITE}%9s${RESET}  ${GREEN}%-18s${RESET}  ${DIM}%2d%%${RESET}\n" \
      "$((i+1))" "${name:0:35}" "$(fmt_kb "$kb")" "$bar" "$pct"
  done

  printf "  ${DIM}%s${RESET}\n" "$(hr '═' 72)"
  printf "  ${BWHITE}Total: ${BGREEN}%s${RESET}  ${DIM}(top %d entries)${RESET}\n\n" \
    "$(fmt_kb "$total_kb")" "${#esizes[@]}"
  p_info "Run: pristine analyze ~/Downloads  to drill into a specific folder"
  echo ""
}

