# ║  UNINSTALL                                                   ║
# ╚══════════════════════════════════════════════════════════════╝

_app_artifacts() {
  local name="$1"
  local locs=(
    "$HOME/Library/Application Support"
    "$HOME/Library/Caches"
    "$HOME/Library/Preferences"
    "$HOME/Library/Logs"
    "$HOME/Library/Saved Application State"
    "$HOME/Library/Containers"
    "$HOME/Library/Group Containers"
    "$HOME/Library/WebKit"
    "$HOME/Library/LaunchAgents"
    "/Library/Application Support"
    "/Library/Preferences"
    "/Library/LaunchAgents"
    "/Library/LaunchDaemons"
    "/Library/PrivilegedHelperTools"
  )
  local name_lower="${name,,}"
  for loc in "${locs[@]}"; do
    [[ -d "$loc" ]] || continue
    find "$loc" -maxdepth 2 \( -iname "*${name}*" \) 2>/dev/null
  done
}

cmd_uninstall() {
  require_macos
  banner
  section "Smart App Uninstaller"
  p_info "Scanning installed applications..."
  echo ""

  local -a app_paths=() app_names=() app_sizes=()

  while IFS= read -r app; do
    [[ -z "$app" ]] && continue
    app_paths+=("$app")
    app_names+=("$(basename "$app" .app)")
    app_sizes+=("$(dir_size_kb "$app")")
  done < <(find /Applications "$HOME/Applications" -maxdepth 1 -name "*.app" 2>/dev/null | sort)

  if [[ ${#app_paths[@]} -eq 0 ]]; then
    p_warn "No applications found."; return
  fi

  printf "  ${DIM}%-3s  %-38s  %9s${RESET}\n" "#" "Application" "Size"
  printf "  ${DIM}%s${RESET}\n" "$(hr '─' 54)"
  for i in "${!app_paths[@]}"; do
    printf "  ${DIM}%2d.${RESET}  ${CYAN}%-38s${RESET}  ${BWHITE}%9s${RESET}\n" \
      "$((i+1))" "${app_names[$i]:0:38}" "$(fmt_kb "${app_sizes[$i]}")"
  done

  echo ""
  printf "  ${BYELLOW}→${RESET}  Enter app number(s) to uninstall ${DIM}(e.g. 1 3 5, or q)${RESET}: "
  local sel; read -r sel </dev/tty
  [[ "$sel" == "q" || "$sel" == "Q" || -z "$sel" ]] && { p_info "Aborted."; return; }

  for num in $sel; do
    [[ "$num" =~ ^[0-9]+$ ]] || continue
    local idx=$(( num - 1 ))
    [[ $idx -lt 0 || $idx -ge ${#app_paths[@]} ]] && { p_warn "Invalid: $num"; continue; }

    local app="${app_paths[$idx]}" name="${app_names[$idx]}"
    echo ""
    printf "  ${BWHITE}Uninstalling: ${BCYAN}%s${RESET}\n" "$name"
    printf "  ${DIM}%s${RESET}\n" "$(hr '─' 54)"

    local -a arts=()
    while IFS= read -r item; do [[ -n "$item" ]] && arts+=("$item"); done \
      < <(_app_artifacts "$name")

    printf "  Found ${BWHITE}%d${RESET} associated files\n" "${#arts[@]}"
    for a in "${arts[@]}"; do printf "    ${DIM}• %s${RESET}\n" "${a/$HOME/~}"; done
    echo ""

    [[ "$DRY_RUN" == true ]] && { p_warn "Dry run — nothing deleted"; continue; }
    confirm "Permanently remove $name and all associated files?" || { p_info "Skipping."; continue; }

    local freed=0
    printf "  ${CYAN}→${RESET}  Removing app bundle..."
    rm -rf "$app" 2>/dev/null && { printf " ${GREEN}✓${RESET}\n"; freed=$(( freed + app_sizes[idx] )); } \
      || printf " ${YELLOW}failed${RESET}\n"

    for art in "${arts[@]}"; do
      local akb; akb=$(dir_size_kb "$art")
      printf "  ${CYAN}→${RESET}  ${DIM}%s${RESET}..." "${art/$HOME/~}"
      rm -rf "$art" 2>/dev/null && { printf " ${GREEN}✓${RESET}\n"; freed=$(( freed + akb )); } \
        || printf " ${YELLOW}failed${RESET}\n"
    done

    printf "\n  ${DIM}%s${RESET}\n  ${BGREEN}✓ Freed %s from %s${RESET}\n" "$(hr '─' 54)" "$(fmt_kb "$freed")" "$name"
  done
  echo ""
}

# ╔══════════════════════════════════════════════════════════════╗
# ║  PURGE                                                       ║
# ╚══════════════════════════════════════════════════════════════╝

cmd_purge() {
  require_macos
  banner
  section "Project Artifact Purge"
  [[ "$DRY_RUN" == true ]] && p_warn "Dry run — no files will be deleted"
  p_info "Scanning for build artifacts..."
  echo ""

  local -a scan_dirs=(
    "$HOME/Desktop" "$HOME/Documents" "$HOME/Projects" "$HOME/dev"
    "$HOME/Developer" "$HOME/Code" "$HOME/Work" "$HOME/Sites"
    "$HOME/github" "$HOME/repos" "$HOME/src"
  )

  local cfg="$HOME/.config/pristine/purge_paths"
  if [[ -f "$cfg" ]]; then
    while IFS= read -r line; do
      [[ -n "$line" && ! "$line" =~ ^# ]] && scan_dirs+=("$line")
    done < "$cfg"
  fi

  local -a patterns=(
    "node_modules" "target" ".build" "build" "dist"
    "__pycache__" ".pytest_cache" "venv" ".venv"
    ".gradle" "Pods" ".next" ".nuxt" ".output"
    ".svelte-kit" "out" ".dart_tool"
  )

  local tmpfile; tmpfile=$(mktemp /tmp/pristine_purge.XXXXXX)

  for dir in "${scan_dirs[@]}"; do
    [[ -d "$dir" ]] || continue
    for pattern in "${patterns[@]}"; do
      find "$dir" -maxdepth 7 -type d -name "$pattern" -prune 2>/dev/null | while read -r found; do
        local kb; kb=$(dir_size_kb "$found")
        [[ "$kb" -gt 0 ]] && printf "%s\t%s\n" "$kb" "$found"
      done
    done
  done | sort -rn > "$tmpfile"

  local -a fpaths=() fsizes=()
  local total_kb=0

  while IFS=$'\t' read -r kb path; do
    [[ -z "$kb" || -z "$path" ]] && continue
    fpaths+=("$path"); fsizes+=("$kb")
    total_kb=$(( total_kb + kb ))
  done < "$tmpfile"
  rm -f "$tmpfile"

  if [[ ${#fpaths[@]} -eq 0 ]]; then
    p_ok "No build artifacts found — projects are already clean!"; return
  fi

  printf "  ${DIM}Found %d artifact directories · %s total${RESET}\n\n" \
    "${#fpaths[@]}" "$(fmt_kb "$total_kb")"

  printf "  ${DIM}%-3s  %-52s  %9s${RESET}\n" "#" "Path" "Size"
  printf "  ${DIM}%s${RESET}\n" "$(hr '─' 68)"
  for i in "${!fpaths[@]}"; do
    local short="${fpaths[$i]/$HOME/~}"
    printf "  ${DIM}%2d.${RESET}  ${CYAN}%-52s${RESET}  ${BWHITE}%9s${RESET}\n" \
      "$((i+1))" "${short:0:52}" "$(fmt_kb "${fsizes[$i]}")"
  done

  echo ""
  printf "  ${BYELLOW}→${RESET}  Enter numbers ${DIM}(e.g. 1-5, 'all', or q to quit)${RESET}: "
  local sel; read -r sel </dev/tty
  [[ "$sel" == "q" || "$sel" == "Q" || -z "$sel" ]] && { p_info "Aborted."; return; }

  local -a idxs=()
  if [[ "$sel" == "all" ]]; then
    for i in "${!fpaths[@]}"; do idxs+=("$i"); done
  else
    for tok in $sel; do
      if [[ "$tok" =~ ^([0-9]+)-([0-9]+)$ ]]; then
        for (( n=${BASH_REMATCH[1]}; n<=${BASH_REMATCH[2]}; n++ )); do
          idxs+=("$(( n - 1 ))")
        done
      elif [[ "$tok" =~ ^[0-9]+$ ]]; then
        idxs+=("$(( tok - 1 ))")
      fi
    done
  fi

  [[ ${#idxs[@]} -eq 0 ]] && { p_warn "No valid selection."; return; }

  local sel_kb=0
  for idx in "${idxs[@]}"; do
    [[ $idx -ge 0 && $idx -lt ${#fpaths[@]} ]] && sel_kb=$(( sel_kb + fsizes[idx] ))
  done

  echo ""
  confirm "Permanently delete ${#idxs[@]} directories ($(fmt_kb "$sel_kb"))?" || {
    p_info "Aborted."; return
  }

  section "Purging"
  echo ""

  local freed_kb=0
  for idx in "${idxs[@]}"; do
    [[ $idx -lt 0 || $idx -ge ${#fpaths[@]} ]] && continue
    local path="${fpaths[$idx]}" kb="${fsizes[$idx]}"
    local short="${path/$HOME/~}"
    printf "  ${CYAN}→${RESET}  %-56s" "${short:0:56}..."
    if [[ "$DRY_RUN" == true ]]; then
      printf "  ${DIM}dry-run${RESET}\n"
    elif rm -rf "${path:?}" 2>/dev/null; then
      printf "  ${GREEN}✓ %s${RESET}\n" "$(fmt_kb "$kb")"
      freed_kb=$(( freed_kb + kb ))
    else
      printf "  ${YELLOW}failed${RESET}\n"
    fi
  done

  echo ""
  printf "  ${DIM}%s${RESET}\n" "$(hr '═' 58)"
  printf "  ${BGREEN}✓ Space freed: %s${RESET}\n" "$(fmt_kb "$freed_kb")"
  printf "  ${DIM}%s${RESET}\n\n" "$(hr '═' 58)"
}

# ╔══════════════════════════════════════════════════════════════╗
# ║  DOCTOR                                                      ║
# ╚══════════════════════════════════════════════════════════════╝

cmd_doctor() {
  require_macos
  banner
  section "System Health Report"
  echo ""

  local ok=0 warn=0 crit=0

  _check() {
    local label="$1" status="$2" detail="$3"
    case "$status" in
      ok)   p_ok   "$(printf '%-40s %s' "$label" "$detail")"; (( ok++   )) ;;
      warn) p_warn "$(printf '%-40s %s' "$label" "$detail")"; (( warn++ )) ;;
      crit) p_err  "$(printf '%-40s %s' "$label" "$detail")"; (( crit++ )) ;;
    esac
  }

  # Disk
  local dpct dfree
  dpct=$(df -k / 2>/dev/null | awk 'NR==2{printf "%.0f", $3*100/$2}')
  dfree=$(df -k / 2>/dev/null | awk 'NR==2{printf "%.1f", $4/1048576}')
  if   (( dpct > 90 )); then _check "Disk space (${dfree}GB free)" crit "${dpct}% used — critically low"
  elif (( dpct > 75 )); then _check "Disk space (${dfree}GB free)" warn "${dpct}% used — getting full"
  else                        _check "Disk space (${dfree}GB free)" ok   "${dpct}% used"
  fi

  # Memory
  local mpct
  mpct=$(vm_stat 2>/dev/null | awk '
    /Pages active/{a=$3+0} /Pages wired/{w=$4+0} /compressor/{c=$5+0}
    END{tot=a+w+c; if(tot>0) printf "%.0f", tot*100/(tot+100000); else print 0}')
  if   (( ${mpct:-0} > 85 )); then _check "Memory pressure" crit "High — ${mpct}%"
  elif (( ${mpct:-0} > 65 )); then _check "Memory pressure" warn "Elevated — ${mpct}%"
  else                              _check "Memory pressure" ok   "Normal — ${mpct}%"
  fi

  # Trash
  local trash_kb; trash_kb=$(dir_size_kb "$HOME/.Trash")
  if   (( trash_kb > 5242880 )); then _check "Trash" warn "$(fmt_kb "$trash_kb") — consider emptying"
  else                                 _check "Trash" ok   "$(fmt_kb "$trash_kb")"
  fi

  # User caches
  local cache_kb; cache_kb=$(dir_size_kb "$HOME/Library/Caches")
  if   (( ${cache_kb:-0} > 20971520 )); then _check "User caches" warn "$(fmt_kb "$cache_kb") — run 'pristine clean'"
  else                                        _check "User caches" ok   "$(fmt_kb "${cache_kb:-0}")"
  fi

  # Xcode DerivedData
  local xdd="$HOME/Library/Developer/Xcode/DerivedData"
  if [[ -d "$xdd" ]]; then
    local xkb; xkb=$(dir_size_kb "$xdd")
    if (( xkb > 5242880 )); then _check "Xcode DerivedData" warn "$(fmt_kb "$xkb") — run 'pristine clean'"
    else                          _check "Xcode DerivedData" ok   "$(fmt_kb "$xkb")"
    fi
  fi

  # npm cache
  if [[ -d "$HOME/.npm/_cacache" ]]; then
    local nkb; nkb=$(dir_size_kb "$HOME/.npm/_cacache")
    if (( nkb > 2097152 )); then _check "npm cache" warn "$(fmt_kb "$nkb") — run 'pristine clean'"
    else                          _check "npm cache" ok   "$(fmt_kb "$nkb")"
    fi
  fi

  # SSD SMART
  local smart; smart=$(diskutil info / 2>/dev/null | awk '/SMART Status/{print $3}')
  if [[ "$smart" == "Verified" || "$smart" == "Not Supported" || -z "$smart" ]]; then
    _check "SSD SMART status" ok "${smart:-Verified}"
  else
    _check "SSD SMART status" crit "$smart"
  fi

  # macOS version
  _check "macOS version" ok "$(sw_vers -productVersion 2>/dev/null)"

  # Uptime
  local udays; udays=$(uptime 2>/dev/null | awk '/day/{match($0, /([0-9]+) day/, d); print d[1]+0}')
  if   (( ${udays:-0} > 30 )); then _check "System uptime" warn "${udays} days — restart recommended"
  elif (( ${udays:-0} > 14 )); then _check "System uptime" warn "${udays} days"
  else  _check "System uptime" ok "$(uptime 2>/dev/null | awk -F'up ' '{print $2}' | awk -F',' '{print $1}' | xargs)"
  fi

  echo ""
  printf "  ${DIM}%s${RESET}\n" "$(hr '═' 58)"
  printf "  ${BGREEN}Passed: %d${RESET}  ${BYELLOW}Warnings: %d${RESET}  ${BRED}Critical: %d${RESET}\n\n" "$ok" "$warn" "$crit"

  if   (( crit > 0 )); then p_warn "Run 'pristine clean' and 'pristine optimize' to address issues."
  elif (( warn > 0 )); then p_info "Run 'pristine clean' to reclaim space."
  else                       p_ok  "Your Mac is in excellent shape!"
  fi
  echo ""
}

