# ║  OPTIMIZE                                                    ║
# ╚══════════════════════════════════════════════════════════════╝

cmd_optimize() {
  require_macos
  banner
  section "System Optimization"
  [[ "$DRY_RUN" == true ]] && p_warn "Dry run — no changes will be made"

  # Show system summary
  local disk_used disk_total mem_gb uptime_str os_ver
  disk_used=$(df -k / 2>/dev/null | awk 'NR==2{print $3+0}')
  disk_total=$(df -k / 2>/dev/null | awk 'NR==2{print $2+0}')
  mem_gb=$(sysctl -n hw.memsize 2>/dev/null | awk '{printf "%dGB", $1/1073741824}')
  uptime_str=$(uptime 2>/dev/null | awk -F'up ' '{print $2}' | awk -F',' '{print $1}' | xargs)
  os_ver=$(sw_vers -productVersion 2>/dev/null)

  printf "\n  ${DIM}macOS %s · %s RAM · Disk %s used · Uptime: %s${RESET}\n\n" \
    "$os_ver" "$mem_gb" "$(fmt_kb "$disk_used")" "$uptime_str"

  # Non-sudo steps (run always)
  local -a steps=(
    "Rebuild Dock|killall Dock"
    "Restart Finder|killall Finder"
    "Clear old .DS_Store files|find ~ -name '.DS_Store' -type f -delete"
    "Remove download quarantine flags|xattr -d -r com.apple.quarantine ~/Downloads"
    "Rebuild Launch Services database|/System/Library/Frameworks/CoreServices.framework/Frameworks/LaunchServices.framework/Support/lsregister -kill -r -domain local -domain system -domain user"
  )

  for entry in "${steps[@]}"; do
    local name="${entry%%|*}" cmd="${entry##*|}"
    printf "  ${CYAN}→${RESET}  %-50s" "$name..."
    if [[ "$DRY_RUN" == true ]]; then
      printf "  ${DIM}dry-run${RESET}\n"
    elif eval "$cmd" &>/dev/null; then
      printf "  ${GREEN}✓${RESET}\n"
    else
      printf "  ${YELLOW}skipped${RESET}\n"
    fi
  done

  # Sudo steps — only if sudo is available without a password prompt
  echo ""
  if can_sudo; then
    printf "  ${DIM}Sudo available — running privileged optimizations...${RESET}\n\n"
    local -a sudo_steps=(
      "Flush DNS cache|sudo dscacheutil -flushcache && sudo killall -HUP mDNSResponder"
      "Flush font cache|sudo atsutil databases -removeUser"
      "Run daily maintenance|sudo periodic daily"
      "Run weekly maintenance|sudo periodic weekly"
      "Purge inactive memory|sudo purge"
    )
    for entry in "${sudo_steps[@]}"; do
      local name="${entry%%|*}" cmd="${entry##*|}"
      printf "  ${CYAN}→${RESET}  %-50s" "$name..."
      if [[ "$DRY_RUN" == true ]]; then
        printf "  ${DIM}dry-run${RESET}\n"
      elif eval "$cmd" &>/dev/null; then
        printf "  ${GREEN}✓${RESET}\n"
      else
        printf "  ${YELLOW}skipped${RESET}\n"
      fi
    done
  else
    printf "  ${DIM}Tip: run ${RESET}${BWHITE}sudo pristine optimize${RESET}${DIM} for full optimization (DNS flush, memory purge)${RESET}\n"
  fi

  echo ""
  printf "  ${DIM}%s${RESET}\n" "$(hr '═' 58)"
  printf "  ${BGREEN}✓ System optimization complete${RESET}\n"
  printf "  ${DIM}%s${RESET}\n\n" "$(hr '═' 58)"
}

