# ║  DOCTOR (System health report)                               ║
# ╚══════════════════════════════════════════════════════════════╝

cmd_doctor() {
  require_macos
  banner
  section "System Health Report"
  echo ""

  local ok=0 warn=0 crit=0

  _check() {
    local label="$1" status="$2" detail="$3"
    case "$status" in
      ok)   p_ok   "$(printf '%-38s %s' "$label" "$detail")"; (( ok++ ));;
      warn) p_warn "$(printf '%-38s %s' "$label" "$detail")"; (( warn++ ));;
      crit) p_err  "$(printf '%-38s %s' "$label" "$detail")"; (( crit++ ));;
    esac
  }

  # Disk space
  local disk_pct; disk_pct=$(df -k / 2>/dev/null | awk 'NR==2{printf "%.0f", $3*100/$2}')
  local disk_free_gb; disk_free_gb=$(df -k / 2>/dev/null | awk 'NR==2{printf "%.1f", $4/1048576}')
  if   (( disk_pct > 90 )); then _check "Disk space ($disk_free_gb GB free)" crit "${disk_pct}% used — critically low"
  elif (( disk_pct > 75 )); then _check "Disk space ($disk_free_gb GB free)" warn "${disk_pct}% used — getting full"
  else                            _check "Disk space ($disk_free_gb GB free)" ok   "${disk_pct}% used"
  fi

  # Memory pressure
  local mem_pct; mem_pct=$(vm_stat 2>/dev/null | awk '
    /Pages active/{a=$3+0}
    /Pages wired/{w=$4+0}
    /compressor/{c=$5+0}
    END{ if(a+w+c>0) printf "%.0f",(a+w+c)*100/(a+w+c+100000); else print 0}
  ')
  if   (( ${mem_pct:-0} > 90 )); then _check "Memory pressure" crit "High — ${mem_pct}%"
  elif (( ${mem_pct:-0} > 70 )); then _check "Memory pressure" warn "Elevated — ${mem_pct}%"
  else                                 _check "Memory pressure" ok   "Normal — ${mem_pct}%"
  fi

  # Trash size
  local trash_kb; trash_kb=$(dir_size_kb "$HOME/.Trash")
  if   (( trash_kb > 5242880 )); then _check "Trash"  warn "$(fmt_kb "$trash_kb") — consider emptying"
  elif (( trash_kb > 1048576 )); then _check "Trash"  warn "$(fmt_kb "$trash_kb")"
  else                                _check "Trash"   ok   "$(fmt_kb "$trash_kb")"
  fi

  # User cache size
  local cache_kb; cache_kb=$(dir_size_kb "$HOME/Library/Caches")
  if   (( cache_kb > 20971520 )); then _check "User caches"  warn "$(fmt_kb "$cache_kb") — run 'pristine clean'"
  else                                  _check "User caches"  ok   "$(fmt_kb "$cache_kb")"
  fi

  # Xcode DerivedData
  local xc_dd="$HOME/Library/Developer/Xcode/DerivedData"
  if [[ -d "$xc_dd" ]]; then
    local xc_kb; xc_kb=$(dir_size_kb "$xc_dd")
    if (( xc_kb > 5242880 )); then _check "Xcode DerivedData" warn "$(fmt_kb "$xc_kb") — run 'pristine clean'"
    else                            _check "Xcode DerivedData" ok   "$(fmt_kb "$xc_kb")"
    fi
  fi

  # npm cache
  local npm_kb; npm_kb=$(dir_size_kb "$HOME/.npm/_cacache")
  if (( ${npm_kb:-0} > 2097152 )); then _check "npm cache" warn "$(fmt_kb "$npm_kb") — run 'pristine clean'"
  elif [[ -d "$HOME/.npm/_cacache" ]];   then _check "npm cache" ok "$(fmt_kb "$npm_kb")"
  fi

  # SSD SMART status
  local smart; smart=$(diskutil info / 2>/dev/null | awk '/SMART Status/{print $3}')
  if [[ "$smart" == "Verified" || "$smart" == "Not Supported" ]]; then
    _check "SSD SMART status" ok "${smart:-Unknown}"
  else
    _check "SSD SMART status" crit "${smart:-Unknown}"
  fi

  # macOS version
  local os_ver; os_ver=$(sw_vers -productVersion 2>/dev/null)
  _check "macOS version" ok "$os_ver"

  # Uptime
  local uptime_days; uptime_days=$(uptime 2>/dev/null | awk '/day/{match($0, /([0-9]+) day/, d); print d[1]+0}')
  if   (( ${uptime_days:-0} > 30 )); then _check "System uptime" warn "${uptime_days} days — consider restarting"
  elif (( ${uptime_days:-0} > 14 )); then _check "System uptime" warn "${uptime_days} days — restart recommended"
  else                                     _check "System uptime" ok   "$(uptime | awk -F'up ' '{print $2}' | awk -F',' '{print $1}' | xargs)"
  fi

  # Rosetta
  if /usr/bin/pgrep oahd &>/dev/null; then
    _check "Rosetta 2" ok "Running (some apps need it)"
  fi

  echo ""
  printf "  ${DIM}%s${RESET}\n" "$(hr '═' 58)"
  printf "  ${BGREEN}Passed: %d${RESET}  ${BYELLOW}Warnings: %d${RESET}  ${BRED}Critical: %d${RESET}\n" "$ok" "$warn" "$crit"
  printf "  ${DIM}%s${RESET}\n\n" "$(hr '═' 58)"

  if (( crit > 0 )); then
    p_warn "Run 'pristine clean' and 'pristine optimize' to address issues."
  elif (( warn > 0 )); then
    p_info "Run 'pristine clean' to reclaim space."
  else
    p_ok "Your Mac is in great shape!"
  fi
  echo ""
}

