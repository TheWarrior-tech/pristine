# ║  STATUS DASHBOARD                                            ║
# ╚══════════════════════════════════════════════════════════════╝

_cpu_pct() {
  top -l 2 -n 0 2>/dev/null | awk '/CPU usage/{
    last=$0
  } END{
    if (last ~ /CPU/) {
      match(last, /([0-9.]+)% user/, u)
      match(last, /([0-9.]+)% sys/, s)
      printf "%.0f", u[1]+s[1]
    } else { print 0 }
  }' 2>/dev/null || echo 0
}

_mem_info() {
  local page_size total
  page_size=$(sysctl -n hw.pagesize 2>/dev/null || echo 4096)
  total=$(sysctl -n hw.memsize 2>/dev/null || echo 0)

  local active wired compr
  active=$(vm_stat 2>/dev/null | awk '/Pages active/{gsub(/\./,""); print $3+0}')
  wired=$(vm_stat 2>/dev/null  | awk '/Pages wired/{gsub(/\./,""); print $4+0}')
  compr=$(vm_stat 2>/dev/null  | awk '/compressor/{gsub(/\./,""); print $5+0}')

  local used=$(( (active + wired + compr) * page_size ))
  local pct; pct=$(awk -v u="$used" -v t="$total" 'BEGIN{if(t>0) printf "%.0f", u*100/t; else print 0}')

  local used_gb; used_gb=$(fmt_bytes "$used")
  local tot_gb;  tot_gb=$(fmt_bytes "$total")
  echo "${used_gb}|${tot_gb}|${pct}"
}

_disk_info() {
  df -k / 2>/dev/null | awk 'NR==2{
    u=$3; t=$2; f=$4
    pct=(t>0)? int(u*100/t) : 0
    printf "%d|%d|%d|%d\n", u, t, f, pct
  }'
}

_net_info() {
  # Returns rx_bytes|tx_bytes
  netstat -ib 2>/dev/null | awk '
    /^en/ && !/Link#/{
      rx+=$7+0; tx+=$10+0
    }
    END{printf "%d|%d\n", rx, tx}
  '
}

_batt_info() {
  local raw; raw=$(pmset -g batt 2>/dev/null)
  local pct status temp
  pct=$(echo "$raw" | grep -o '[0-9]*%' | head -1 | tr -d '%')
  status=$(echo "$raw" | grep -oE '(Charging|AC attached|discharging|charged|finishing charge)' | head -1)
  [[ -z "$pct" ]] && pct="AC"
  [[ -z "$status" ]] && status="Unknown"
  echo "${pct}|${status}"
}

_top_procs() {
  ps axro "comm,pcpu" 2>/dev/null | awk 'NR>1 && NR<=7 {
    gsub(/.*\//,""); printf "%-22s %5.1f%%\n", $1, $2
  }'
}

_health_score() {
  local cpu="$1" mem="$2" disk="$3"
  awk -v c="$cpu" -v m="$mem" -v d="$disk" 'BEGIN{
    score=100
    if (c>80) score-=25; else if (c>60) score-=15; else if (c>40) score-=5
    if (m>90) score-=20; else if (m>75) score-=10; else if (m>60) score-=3
    if (d>90) score-=20; else if (d>80) score-=10; else if (d>70) score-=3
    print int(score)
  }'
}

cmd_status() {
  require_macos

  local model; model=$(sysctl -n machdep.cpu.brand_string 2>/dev/null \
    || system_profiler SPHardwareDataType 2>/dev/null | awk -F': ' '/Chip/{print $2}' \
    || echo "Mac")
  model="${model:0:28}"
  local host; host=$(hostname -s 2>/dev/null || echo "Mac")
  local os_ver; os_ver=$(sw_vers -productVersion 2>/dev/null || echo "macOS")
  local mem_total_gb; mem_total_gb=$(sysctl -n hw.memsize 2>/dev/null | awk '{printf "%.0f", $1/1073741824}')

  tput civis 2>/dev/null
  trap 'tput cnorm 2>/dev/null; tput rmcup 2>/dev/null; echo ""; exit 0' INT TERM EXIT
  tput smcup 2>/dev/null
  clear

  while true; do
    tput cup 0 0 2>/dev/null

    # Gather all metrics
    local cpu_pct; cpu_pct=$(_cpu_pct)
    local mem_info; mem_info=$(_mem_info)
    local mem_used="${mem_info%%|*}"; mem_rest="${mem_info#*|}"; mem_tot="${mem_rest%%|*}"; mem_pct="${mem_rest##*|}"
    local disk_info; disk_info=$(_disk_info)
    local disk_used_kb="${disk_info%%|*}"; di="${disk_info#*|}"; disk_tot_kb="${di%%|*}"; di="${di#*|}"; disk_free_kb="${di%%|*}"; disk_pct="${di##*|}"
    local batt_info; batt_info=$(_batt_info)
    local batt_pct="${batt_info%%|*}"; batt_status="${batt_info##*|}"
    local uptime_str; uptime_str=$(uptime 2>/dev/null | awk -F'up ' '{print $2}' | awk -F', [0-9]+ user' '{print $1}' | xargs)
    local health; health=$(_health_score "$cpu_pct" "$mem_pct" "$disk_pct")

    # Health color
    local hc="$BGREEN"
    [[ "$health" -lt 80 ]] && hc="$BYELLOW"
    [[ "$health" -lt 60 ]] && hc="$BRED"

    # Header
    printf "\n"
    printf "  ${BCYAN}${BOLD}PRISTINE STATUS${RESET}  "
    printf "${DIM}Health ${hc}●${RESET} ${hc}%d${RESET}  " "$health"
    printf "${DIM}%s · %s · %sGB · macOS %s${RESET}\n" "$host" "$model" "$mem_total_gb" "$os_ver"
    printf "\n"

    # CPU
    local load_str; load_str=$(uptime 2>/dev/null | awk -F'load averages:' '{print $2}' | xargs)
    printf "  ${BWHITE}⚙  CPU${RESET}\n"
    printf "  Usage   $(pct_bar "$cpu_pct" 28)  ${BWHITE}%3d%%${RESET}\n" "$cpu_pct"
    printf "  Load    ${DIM}%s${RESET}\n" "$load_str"
    printf "\n"

    # Memory
    printf "  ${BWHITE}▦  Memory${RESET}\n"
    printf "  Used    $(pct_bar "$mem_pct" 28)  ${BWHITE}%3d%%${RESET}\n" "$mem_pct"
    printf "  Usage   ${DIM}%s / %s${RESET}\n" "$mem_used" "$mem_tot"
    printf "\n"

    # Disk
    printf "  ${BWHITE}▤  Disk  ${DIM}(/)${RESET}\n"
    printf "  Used    $(pct_bar "$disk_pct" 28)  ${BWHITE}%3d%%${RESET}\n" "$disk_pct"
    printf "  Free    ${DIM}%s free · %s total${RESET}\n" "$(fmt_kb "$disk_free_kb")" "$(fmt_kb "$disk_tot_kb")"
    printf "\n"

    # Battery
    printf "  ${BWHITE}⚡ Battery${RESET}\n"
    if [[ "$batt_pct" == "AC" ]]; then
      printf "  Power   ${DIM}AC Power (no battery detected)${RESET}\n"
    else
      printf "  Level   $(pct_bar "$batt_pct" 28)  ${BWHITE}%3d%%${RESET}\n" "$batt_pct"
      printf "  Status  ${DIM}%s${RESET}\n" "$batt_status"
    fi
    printf "\n"

    # Top Processes
    printf "  ${BWHITE}▶  Top Processes${RESET}\n"
    _top_procs | while IFS= read -r line; do
      printf "  ${DIM}%s${RESET}\n" "$line"
    done
    printf "\n"

    # Footer
    printf "  ${DIM}%s${RESET}\n" "$(hr '─' 58)"
    printf "  ${DIM}Refreshing every 2s · Press ${RESET}${BWHITE}q${RESET}${DIM} to quit${RESET}\n"
    printf "  ${DIM}%s${RESET}\n" "$(hr '─' 58)"

    if read -r -s -n1 -t 2 k 2>/dev/null; then
      [[ "$k" == "q" || "$k" == "Q" ]] && break
    fi
    clear
  done

  tput cnorm 2>/dev/null
  tput rmcup 2>/dev/null
}

# ╔══════════════════════════════════════════════════════════════╗
# ║  ANALYZE                                                     ║
# ╚══════════════════════════════════════════════════════════════╝

cmd_analyze() {
  require_macos
  local target="${1:-$HOME}"
  [[ -d "$target" ]] || { p_err "Path not found: $target"; exit 1; }

  banner
  section "Disk Analyzer  ${DIM}$(echo "$target" | sed "s|$HOME|~|")"
  p_info "Scanning... (this may take a moment)"
  echo ""

  # Get sorted entries
  local tmpfile; tmpfile=$(mktemp /tmp/pristine_analyze.XXXXXX)
  du -sk "${target}/"* 2>/dev/null | sort -rn > "$tmpfile"

  local total_kb=0
  local -a entry_sizes=()
  local -a entry_paths=()

  while IFS=$'\t' read -r kb path; do
    [[ -z "$kb" || -z "$path" ]] && continue
    entry_sizes+=("$kb")
    entry_paths+=("$path")
    total_kb=$(( total_kb + kb ))
    [[ ${#entry_sizes[@]} -ge 25 ]] && break
  done < "$tmpfile"
  rm -f "$tmpfile"

  local count=${#entry_sizes[@]}
  if [[ $count -eq 0 ]]; then
    p_warn "Nothing found in $target"
    return
  fi

  local total_human; total_human=$(fmt_kb "$total_kb")
  local max_kb="${entry_sizes[0]}"
  [[ "$max_kb" -eq 0 ]] && max_kb=1

  printf "  ${DIM}%-3s  %-36s  %9s  %s${RESET}\n" "#" "Name" "Size" "Usage"
  printf "  ${DIM}%s${RESET}\n" "$(hr '─' 62)"

  for i in "${!entry_paths[@]}"; do
    local path="${entry_paths[$i]}"
    local kb="${entry_sizes[$i]}"
    local name; name=$(basename "$path")
    local human; human=$(fmt_kb "$kb")
    local pct; pct=$(awk -v k="$kb" -v t="$total_kb" 'BEGIN{if(t>0) printf "%.0f", k*100/t; else print 0}')
    local bar_len; bar_len=$(awk -v k="$kb" -v m="$max_kb" 'BEGIN{x=int(k*20/m); if(x<1)x=1; print x}')
    local bar=""; for (( b=0; b<bar_len; b++ )); do bar+="█"; done
    local icon="📄"
    [[ -d "$path" ]] && icon="📁"

    printf "  ${DIM}%2d.${RESET}  ${CYAN}%-35s${RESET}  ${BWHITE}%8s${RESET}  ${GREEN}%-20s${RESET}${DIM} %2d%%${RESET}\n" \
      "$((i+1))" "${name:0:35}" "$human" "$bar" "$pct"
  done

  printf "  ${DIM}%s${RESET}\n" "$(hr '═' 62)"
  printf "  ${BWHITE}Total shown: ${BGREEN}%s${RESET}  ${DIM}(top %d entries)${RESET}\n\n" "$total_human" "$count"

  printf "  ${DIM}Tip: %s${RESET}\n\n" "Run 'pristine analyze ~/Downloads' to drill into a folder"
}

