set -uo pipefail

VERSION="1.0.0"
DRY_RUN=false
DEBUG=false

# ── Guard: macOS only ──────────────────────────────────────────
require_macos() {
  [[ "$(uname)" == "Darwin" ]] || { echo "Pristine requires macOS." >&2; exit 1; }
}

# ── Colors (only when terminal supports it) ────────────────────
setup_colors() {
  if [[ -t 1 ]]; then
    BOLD="\033[1m";    DIM="\033[2m";      RESET="\033[0m"
    RED="\033[0;31m";  GREEN="\033[0;32m"; YELLOW="\033[0;33m"
    BLUE="\033[0;34m"; CYAN="\033[0;36m";  WHITE="\033[0;37m"
    BRED="\033[1;31m"; BGREEN="\033[1;32m";BYELLOW="\033[1;33m"
    BBLUE="\033[1;34m";BCYAN="\033[1;36m"; BWHITE="\033[1;37m"
    BG_CYAN="\033[46m";BG_BLUE="\033[44m"; BG_GREEN="\033[42m"
    INVERT="\033[7m"
  else
    BOLD=""; DIM=""; RESET=""; RED=""; GREEN=""; YELLOW=""
    BLUE=""; CYAN=""; WHITE=""; BRED=""; BGREEN=""; BYELLOW=""
    BBLUE=""; BCYAN=""; BWHITE=""; BG_CYAN=""; BG_BLUE=""
    BG_GREEN=""; INVERT=""
  fi
}
setup_colors

# ── Print Helpers ──────────────────────────────────────────────
hr()      { local c="${1:-═}" w="${2:-62}"; printf '%*s\n' "$w" '' | tr ' ' "$c"; }
p_ok()    { printf "  ${GREEN}✓${RESET}  %s\n" "$*"; }
p_info()  { printf "  ${CYAN}→${RESET}  %s\n" "$*"; }
p_warn()  { printf "  ${YELLOW}⚠${RESET}  %s\n" "$*"; }
p_err()   { printf "  ${RED}✗${RESET}  %s\n" "$*" >&2; }
p_skip()  { printf "  ${DIM}○${RESET}  ${DIM}%s${RESET}\n" "$*"; }

section() { echo ""; printf "  ${BWHITE}%s${RESET}\n  ${DIM}%s${RESET}\n" "$1" "$(hr '─' 58)"; }

banner() {
  printf "\n"
  printf "  ${BCYAN}╔═══════════════════════════════════════════════════╗${RESET}\n"
  printf "  ${BCYAN}║${RESET}   ${BWHITE}✦  PRISTINE${RESET}  ${DIM}— Deep clean and optimize your Mac${RESET}  ${BCYAN}║${RESET}\n"
  printf "  ${BCYAN}╚═══════════════════════════════════════════════════╝${RESET}\n"
  printf "  ${DIM}v%s · Safe by default · Zero dependencies${RESET}\n\n" "$VERSION"
}

# ── Format sizes ───────────────────────────────────────────────
fmt_kb() {
  local kb="$1"
  awk -v kb="$kb" 'BEGIN{
    if (kb >= 1048576)       printf "%.1fGB", kb/1048576
    else if (kb >= 1024)     printf "%.1fMB", kb/1024
    else if (kb > 0)         printf "%dKB", kb
    else                     printf "0B"
  }'
}

fmt_bytes() {
  local b="$1"
  awk -v b="$b" 'BEGIN{
    if (b >= 1073741824)     printf "%.1fGB", b/1073741824
    else if (b >= 1048576)   printf "%.1fMB", b/1048576
    else if (b >= 1024)      printf "%.1fKB", b/1024
    else                     printf "%dB", b
  }'
}

# ── Visual bar (pct 0-100, width chars) ───────────────────────
pct_bar() {
  local pct="$1" width="${2:-24}" color="${3:-$GREEN}"
  local filled
  filled=$(awk -v p="$pct" -v w="$width" 'BEGIN{x=int(p*w/100); if(x>w)x=w; print x}')
  local empty=$(( width - filled ))
  printf "${color}"
  [[ $filled -gt 0 ]] && printf '%0.s█' $(seq 1 $filled)
  printf "${DIM}"
  [[ $empty -gt 0 ]]  && printf '%0.s░' $(seq 1 $empty)
  printf "${RESET}"
}

# ── Confirm prompt ─────────────────────────────────────────────
confirm() {
  local msg="${1:-Are you sure?}"
  printf "  ${BYELLOW}?${RESET}  %s ${DIM}[y/N]${RESET} " "$msg"
  local ans; read -r ans
  [[ "$ans" =~ ^[Yy]$ ]]
}

# ── Get disk size of path ──────────────────────────────────────
dir_size_kb() { du -sk "$1" 2>/dev/null | awk '{print $1+0}'; }

# ── Spinner (run cmd in background, show spinner) ─────────────
with_spinner() {
  local msg="$1"; shift
  local spin=('⠋' '⠙' '⠹' '⠸' '⠼' '⠴' '⠦' '⠧' '⠇' '⠏')
  "$@" &>/tmp/pristine_spin_out &
  local pid=$!
  local i=0
  while kill -0 "$pid" 2>/dev/null; do
    printf "\r  ${CYAN}%s${RESET}  %s  " "${spin[$i]}" "$msg"
    i=$(( (i+1) % 10 ))
    sleep 0.07
  done
  wait "$pid"
  local rc=$?
  printf "\r%*s\r" "$(tput cols 2>/dev/null || echo 80)" ""
  return $rc
}

