# ║  INTERACTIVE MENU                                            ║
# ╚══════════════════════════════════════════════════════════════╝

_read_key() {
  local k seq
  IFS= read -r -s -n1 k 2>/dev/null
  if [[ "$k" == $'\x1b' ]]; then
    IFS= read -r -s -n2 seq 2>/dev/null
    k+="$seq"
  fi
  printf '%s' "$k"
}

cmd_menu() {
  require_macos

  local -a labels=(
    "clean     Deep clean caches, logs & browser data"
    "optimize  Flush DNS, maintenance scripts & services"
    "analyze   Visual disk space breakdown by folder"
    "uninstall Remove apps and all their hidden files"
    "purge     Delete build artifacts (node_modules etc.)"
    "status    Live real-time system health dashboard"
    "doctor    Full system health check & recommendations"
  )

  local -a cmds=(clean optimize analyze uninstall purge status doctor)
  local selected=0
  local total=${#labels[@]}

  tput civis 2>/dev/null
  trap 'tput cnorm 2>/dev/null; clear; echo ""; exit 0' INT TERM EXIT

  while true; do
    clear
    banner

    printf "  ${DIM}↑↓ or j/k to navigate  ·  Enter to run  ·  q to quit${RESET}\n\n"

    for i in "${!labels[@]}"; do
      local label="${labels[$i]}"
      local cmd_name="${label%% *}"
      local desc="${label#* }"

      if [[ $i -eq $selected ]]; then
        printf "  ${BCYAN}${BOLD} ▶  %-12s${RESET}  %s\n" "$cmd_name" "$desc"
      else
        printf "     ${CYAN}%-12s${RESET}  ${DIM}%s${RESET}\n" "$cmd_name" "$desc"
      fi
    done

    printf "\n  ${DIM}%s${RESET}\n" "$(hr '─' 58)"
    printf "  ${DIM}Pristine v%s · %s · macOS %s${RESET}\n" \
      "$VERSION" "$(sysctl -n machdep.cpu.brand_string 2>/dev/null | awk '{print $1,$2}' || echo Mac)" \
      "$(sw_vers -productVersion 2>/dev/null)"

    local key; key=$(_read_key)

    case "$key" in
      $'\x1b[A'|k|K) (( selected > 0 )) && (( selected-- )) || selected=$(( total - 1 )) ;;
      $'\x1b[B'|j|J) (( selected < total - 1 )) && (( selected++ )) || selected=0 ;;
      $'\n'|$'\r'|'')
        local chosen="${cmds[$selected]}"
        tput cnorm 2>/dev/null
        clear
        case "$chosen" in
          clean)     cmd_clean ;;
          optimize)  cmd_optimize ;;
          analyze)   cmd_analyze ;;
          uninstall) cmd_uninstall ;;
          purge)     cmd_purge ;;
          status)    cmd_status ;;
          doctor)    cmd_doctor ;;
        esac
        tput civis 2>/dev/null
        printf "  ${DIM}Press any key to return to menu...${RESET}"
        read -r -s -n1
        ;;
      q|Q)
        break
        ;;
    esac
  done

  tput cnorm 2>/dev/null
  clear
  banner
  printf "  ${BGREEN}Thanks for using Pristine!${RESET}\n"
  printf "  ${DIM}If it helped, consider starring the repo ⭐${RESET}\n\n"
}

